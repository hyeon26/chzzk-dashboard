{
  "crons": [{ "path": "/api/cache-clips", "schedule": "0 19 * * *" }],
  "redirects": [
    {
      "source": "/((?!vote$|logo\\.png$|donation$|api/).*)",
      "has": [{ "type": "host", "value": "cheotdool.vercel.app" }],
      "destination": "/__blocked__",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/schedule", "destination": "/index.html" },
    { "source": "/content", "destination": "/index.html" },
    { "source": "/tools", "destination": "/index.html" },
    { "source": "/chat", "destination": "/index.html" },
    { "source": "/clips", "destination": "/index.html" },
    { "source": "/vote", "destination": "/vote.html" },
    { "source": "/logs", "destination": "/logs.html" },
    { "source": "/donation", "destination": "/donation.html" },
    { "source": "/roulette", "destination": "/roulette.html" },
    { "source": "/cheeze", "destination": "/cheeze.html" }
  ]
}
